<script>
  // Garantie-Badges nach ATC-Button einfügen
  document.addEventListener('DOMContentLoaded', function() {
    var atcBtn = document.querySelector('.product-form__submit');
    var guarantee = document.getElementById('vercto-guarantee');
    if (atcBtn && guarantee) {
      atcBtn.closest('.product-form')
        ? atcBtn.closest('.product-form').after(guarantee)
        : atcBtn.after(guarantee);
      guarantee.style.display = 'flex';
      guarantee.style.flexDirection = 'column';
    }

    // Sticky ATC Bar
    var stickyBar = document.getElementById('vercto-sticky-atc');
    var stickyBtn = document.getElementById('vercto-sticky-atc-btn');
    var buyBox = document.querySelector('.product-form__submit');

    if (stickyBar && buyBox) {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (!entry.isIntersecting) {
            stickyBar.classList.add('is-visible');
          } else {
            stickyBar.classList.remove('is-visible');
          }
        });
      }, { threshold: 0 });
      observer.observe(buyBox);
    }

    if (stickyBtn) {
      stickyBtn.addEventListener('click', function() {
        var form = document.querySelector('.product-form form');
        if (form) form.querySelector('[name="add"]').click();
      });
    }
  });

  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('[id^="VerctoNav-"]').forEach(function(nav) {
      var sectionId = nav.id.replace('VerctoNav-', '');
      var slider = document.getElementById('Slider-Gallery-' + sectionId);
      if (!slider) return;

      var items = Array.from(slider.querySelectorAll('.product__media-item'));
      if (items.length === 0) return;

      var current = 0;

      function goTo(index) {
        if (index < 0) index = items.length - 1;
        if (index >= items.length) index = 0;
        items[current].classList.remove('vercto-active');
        current = index;
        items[current].classList.add('vercto-active');
      }

      // Erstes Bild aktivieren
      items[0].classList.add('vercto-active');

      nav.querySelector('.vercto-slider-btn--prev').addEventListener('click', function() {
        goTo(current - 1);
      });
      nav.querySelector('.vercto-slider-btn--next').addEventListener('click', function() {
        goTo(current + 1);
      });
    });
  });
</script>
