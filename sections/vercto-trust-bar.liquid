<style>
  .vercto-trust {
    background-color: #F9F9F9;
    padding: 48px 24px;
  }

  .vercto-trust__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    align-items: start;
  }

  .vercto-trust__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
  }

  .vercto-trust__icon {
    width: 40px;
    height: 40px;
    color: #2563EB;
  }

  .vercto-trust__title {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 15px;
    color: #0C0C0E;
    margin: 0;
  }

  .vercto-trust__desc {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 14px;
    color: #888888;
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .vercto-trust__inner {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px 16px;
    }
    .vercto-trust {
      padding: 48px 20px;
    }
  }
</style>

<div class="vercto-trust">
  <div class="vercto-trust__inner">
    <div class="vercto-trust__item">
      <svg class="vercto-trust__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
      </svg>
      <p class="vercto-trust__title">Free Shipping</p>
      <p class="vercto-trust__desc">On all orders worldwide</p>
    </div>
    <div class="vercto-trust__item">
      <svg class="vercto-trust__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3" />
      </svg>
      <p class="vercto-trust__title">30-Day Returns</p>
      <p class="vercto-trust__desc">No questions asked</p>
    </div>
    <div class="vercto-trust__item">
      <svg class="vercto-trust__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
      </svg>
      <p class="vercto-trust__title">2-Year Warranty</p>
      <p class="vercto-trust__desc">Full coverage guaranteed</p>
    </div>
    <div class="vercto-trust__item">
      <svg class="vercto-trust__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />
      </svg>
      <p class="vercto-trust__title">Science-Backed</p>
      <p class="vercto-trust__desc">Clinically tested design</p>
    </div>
  </div>
</div>

