{% comment %} =====================================================
  URTALLOW — Problem / Lösung Section
  Zwei Spalten, linke Akzentlinie
===================================================== {% endcomment %}

<section class="ur-probsol ur-section" id="warum-tallow">
  <div class="ur-container">
    <div class="ur-probsol__grid">

      <!-- Problem -->
      <div class="ur-probsol__col ur-probsol__col--problem">
        <div class="ur-accent-line ur-accent-line--dark"></div>
        <h2 class="ur-probsol__headline">{{ section.settings.problem_headline }}</h2>
        <p class="ur-probsol__body">{{ section.settings.problem_text }}</p>
      </div>

      <!-- Lösung -->
      <div class="ur-probsol__col ur-probsol__col--solution">
        <div class="ur-accent-line"></div>
        <h2 class="ur-probsol__headline">{{ section.settings.solution_headline }}</h2>
        <p class="ur-probsol__body">{{ section.settings.solution_text }}</p>
      </div>

    </div>
  </div>
</section>

<style>
.ur-probsol {
  background: var(--color-cream);
}

.ur-probsol__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  border: 1px solid var(--color-border);
}

.ur-probsol__col {
  padding: 64px 52px;
}

.ur-probsol__col--problem {
  border-right: 1px solid var(--color-border);
}

.ur-probsol__headline {
  font-family: var(--font-heading);
  font-size: clamp(22px, 2.8vw, 32px);
  font-weight: var(--fw-regular);
  color: var(--color-black);
  margin-bottom: 20px;
  line-height: 1.25;
}

.ur-probsol__body {
  font-size: 16px;
  line-height: 1.75;
  color: var(--color-muted);
}

@media (max-width: 768px) {
  .ur-probsol__grid {
    grid-template-columns: 1fr;
  }
  .ur-probsol__col {
    padding: 40px 28px;
  }
  .ur-probsol__col--problem {
    border-right: none;
    border-bottom: 1px solid var(--color-border);
  }
}
</style>

{% schema %}
{
  "name": "Problem / Lösung",
  "settings": [
    {
      "type": "text",
      "id": "problem_headline",
      "label": "Problem Headline",
      "default": "Das Problem mit deiner Creme"
    },
    {
      "type": "textarea",
      "id": "problem_text",
      "label": "Problem Text",
      "default": "Konventionelle Cremes erzeugen eine künstliche Barriere. Die Haut stellt ihre eigene Produktion zurück. Du brauchst immer mehr. Der Kreislauf beginnt."
    },
    {
      "type": "text",
      "id": "solution_headline",
      "label": "Lösung Headline",
      "default": "Warum Tallow anders wirkt"
    },
    {
      "type": "textarea",
      "id": "solution_text",
      "label": "Lösung Text",
      "default": "Rindertalg enthält dieselben Fettsäuren die deine Haut selbst produziert. Keine künstlichen Zusätze. Keine Abhängigkeit. Deine Haut erkennt es."
    }
  ],
  "presets": [
    {
      "name": "Problem / Lösung"
    }
  ]
}
{% endschema %}
