{% comment %} =====================================================
  URTALLOW — Navigation / Header
  Logo zentriert, Warenkorb rechts, kein Menü
===================================================== {% endcomment %}

<header class="ur-header" id="urtallow-header" role="banner">
  <div class="ur-header__inner ur-container">

    <!-- Linke Seite: Platzhalter für Balance -->
    <div class="ur-header__left" aria-hidden="true"></div>

    <!-- Logo zentriert -->
    <a href="{{ routes.root_url }}" class="ur-header__logo" aria-label="{{ shop.name }} – Startseite">
      <span class="ur-logo__ur">UR</span><span class="ur-logo__tallow">TALLOW</span>
    </a>

    <!-- Rechts: Warenkorb -->
    <div class="ur-header__actions">
      <a href="{{ routes.cart_url }}" class="ur-header__cart" aria-label="Warenkorb ({{ cart.item_count }} Artikel)">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="ur-cart__badge" aria-live="polite">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>

  </div>
</header>

<style>
.ur-header {
  position: sticky;
  top: 0;
  z-index: 90;
  background: var(--color-cream);
  border-bottom: 1px solid var(--color-border);
}

.ur-header__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 68px;
}

/* Balancing placeholder — same width as cart area */
.ur-header__left {
  width: 44px;
  flex-shrink: 0;
}

/* Logo */
.ur-header__logo {
  font-family: var(--font-body);
  font-weight: var(--fw-medium);
  font-size: 20px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  display: flex;
  align-items: center;
}
.ur-logo__ur     { color: var(--color-gold); }
.ur-logo__tallow { color: var(--color-black); }

/* Actions */
.ur-header__actions {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.ur-header__cart {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-black);
  transition: color var(--transition);
  cursor: pointer;
  min-width: 44px;
  min-height: 44px;
}
.ur-header__cart:hover { color: var(--color-gold); }

.ur-cart__badge {
  position: absolute;
  top: 0;
  right: 0;
  background: var(--color-gold);
  color: var(--color-white);
  font-size: 10px;
  font-weight: var(--fw-medium);
  width: 18px;
  height: 18px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
</style>

{% schema %}
{
  "name": "Header"
}
{% endschema %}
