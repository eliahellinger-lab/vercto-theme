{% comment %} =====================================================
  URTALLOW — Trust Bar Section
  4 Icons in einer Reihe, Cream BG
===================================================== {% endcomment %}

<section class="ur-trust" aria-label="Vertrauenssignale">
  <div class="ur-container">
    <div class="ur-trust__grid">
      {%- for block in section.blocks -%}
        <div class="ur-trust__item" {{ block.shopify_attributes }}>
          <div class="ur-trust__icon" aria-hidden="true">
            {%- if block.settings.icon == 'shipping' -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="3" width="15" height="13" rx="1"/>
                <path d="M16 8h4l3 5v3h-7V8z"/>
                <circle cx="5.5" cy="18.5" r="2.5"/>
                <circle cx="18.5" cy="18.5" r="2.5"/>
              </svg>
            {%- elsif block.settings.icon == 'return' -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="1 4 1 10 7 10"/>
                <path d="M3.51 15a9 9 0 102.13-9.36L1 10"/>
              </svg>
            {%- elsif block.settings.icon == 'natural' -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 8C8 10 5.9 16.17 3.82 19.9A2 2 0 002 22c0-7.73 5.65-14.39 13-16l2 2zm2 2l-2-2c0 5-3.5 9.06-8 10 5-1 10-5 10-10z"/>
              </svg>
            {%- elsif block.settings.icon == 'delivery' -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            {%- else -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            {%- endif -%}
          </div>
          <p class="ur-trust__label">{{ block.settings.label }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
.ur-trust {
  background: var(--color-cream-dark);
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
  padding: 52px 0;
}

.ur-trust__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: var(--color-border);
  border: 1px solid var(--color-border);
}

.ur-trust__item {
  background: var(--color-cream-dark);
  padding: 32px 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 14px;
}

.ur-trust__icon {
  width: 40px;
  height: 40px;
  color: var(--color-gold);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ur-trust__icon svg {
  width: 100%;
  height: 100%;
}

.ur-trust__label {
  font-size: 13px;
  font-weight: var(--fw-medium);
  letter-spacing: 0.04em;
  color: var(--color-black);
  line-height: 1.4;
  margin: 0;
}

@media (max-width: 600px) {
  .ur-trust__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
</style>

{% schema %}
{
  "name": "Trust Bar",
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Punkt",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shipping",  "label": "Versand" },
            { "value": "return",    "label": "Rückgabe" },
            { "value": "natural",   "label": "Natur" },
            { "value": "delivery",  "label": "Lieferzeit" },
            { "value": "shield",    "label": "Schild" }
          ],
          "default": "shipping"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Text",
          "default": "Versandkostenfrei ab 29€"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "shipping",  "label": "Versandkostenfrei ab 29€" } },
        { "type": "trust_item", "settings": { "icon": "return",    "label": "30 Tage Rückgabe" } },
        { "type": "trust_item", "settings": { "icon": "natural",   "label": "Natürliche Inhaltsstoffe" } },
        { "type": "trust_item", "settings": { "icon": "delivery",  "label": "Lieferung 6–10 Werktage" } }
      ]
    }
  ]
}
{% endschema %}
