{% comment %} =====================================================
  URTALLOW — Hero Section
  Vollbreite, Cream BG, Headline + Bild
===================================================== {% endcomment %}

<section class="ur-hero ur-section" id="hero">
  <div class="ur-container">
    <div class="ur-hero__grid">

      <!-- Text Block -->
      <div class="ur-hero__content">
        <p class="ur-hero__eyebrow">{{ section.settings.eyebrow }}</p>
        <h1 class="ur-hero__headline">{{ section.settings.headline }}</h1>
        <p class="ur-hero__sub">{{ section.settings.subheadline }}</p>

        <div class="ur-hero__actions">
          <a href="{{ section.settings.cta_url }}" class="ur-btn ur-btn--primary">
            {{ section.settings.cta_text }}
          </a>
        </div>

        <!-- Trust micro-signals -->
        <div class="ur-hero__trust">
          <div class="ur-stars" aria-label="5 von 5 Sternen">
            {%- for i in (1..5) -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {%- endfor -%}
          </div>
          <span class="ur-hero__trust-text">{{ section.settings.trust_text }}</span>
        </div>
      </div>

      <!-- Product Image -->
      <div class="ur-hero__media">
        {%- if section.settings.product_image != blank -%}
          <img
            src="{{ section.settings.product_image | img_url: '700x700', crop: 'center' }}"
            srcset="{{ section.settings.product_image | img_url: '400x400', crop: 'center' }} 400w,
                    {{ section.settings.product_image | img_url: '700x700', crop: 'center' }} 700w"
            sizes="(max-width: 768px) 100vw, 50vw"
            alt="{{ section.settings.product_image.alt | default: 'URTALLOW Whipped Cream' }}"
            width="700" height="700"
            loading="eager"
            class="ur-hero__img"
          >
        {%- else -%}
          <div class="ur-hero__img-placeholder" aria-hidden="true">
            <span>Produktbild</span>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

<style>
.ur-hero {
  background: var(--color-cream);
  padding-top: 80px;
  padding-bottom: 80px;
  overflow: hidden;
}

.ur-hero__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}

/* --- Content --- */
.ur-hero__eyebrow {
  font-size: 12px;
  font-weight: var(--fw-medium);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-gold);
  margin-bottom: 20px;
}

.ur-hero__headline {
  font-family: var(--font-heading);
  font-size: clamp(34px, 4.5vw, 58px);
  font-weight: var(--fw-regular);
  line-height: 1.15;
  color: var(--color-black);
  margin-bottom: 24px;
}

.ur-hero__sub {
  font-size: clamp(16px, 1.5vw, 20px);
  color: var(--color-muted);
  line-height: 1.6;
  margin-bottom: 40px;
  max-width: 460px;
}

.ur-hero__actions {
  margin-bottom: 32px;
}

.ur-hero__trust {
  display: flex;
  align-items: center;
  gap: 10px;
}

.ur-hero__trust-text {
  font-size: 13px;
  font-weight: var(--fw-medium);
  color: var(--color-muted);
  letter-spacing: 0.02em;
}

/* --- Image --- */
.ur-hero__media {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ur-hero__img {
  width: 100%;
  max-width: 520px;
  height: auto;
  object-fit: cover;
}

.ur-hero__img-placeholder {
  width: 100%;
  max-width: 480px;
  aspect-ratio: 1;
  background: var(--color-cream-dark);
  border: 2px dashed var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-muted);
  font-size: 14px;
  letter-spacing: 0.04em;
}

/* --- Responsive --- */
@media (max-width: 900px) {
  .ur-hero__grid {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .ur-hero__media { order: -1; }
  .ur-hero__sub   { max-width: 100%; }
  .ur-hero__img   { max-width: 320px; margin: 0 auto; }
}
</style>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "100% Natürlich · Grass-Fed"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Headline (H1)",
      "default": "Hautpflege wie vor 3000 Jahren. Bevor die Industrie sie ersetzte."
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Ein Inhaltsstoff. Keine Chemie. Keine Abhängigkeit."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Jetzt entdecken"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Link",
      "default": "/products/urtallow-whipped-cream"
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Trust Text",
      "default": "Über 2.400 zufriedene Kundinnen"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Produktbild"
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}
